# ── CropView Environment Variables ──

# Mapbox token — used server-side for geocoding (county/address search)
# Get one free at: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=pk.your_mapbox_token_here

# Only needed if using the Mapbox map variant (satellite imagery)
# Uncomment the line below and set your token:
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
